{
  "name": "oidc-provider-dev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "generate": "tsx scripts/build-from-upstream.ts",
    "generate:v8": "OIDC_VERSION=v8 tsx scripts/build-from-upstream.ts",
    "generate:all": "npm run generate && npm run generate:v8",
    "generate:refresh": "UPSTREAM_REFRESH=1 npm run generate:all",
    "dev": "npm run generate:all && astro dev",
    "start": "astro dev",
    "build": "npm run generate:all && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.38.2",
    "@types/keygrip": "^1.0.6",
    "@types/koa": "^3.0.2",
    "@types/oidc-provider": "^9.5.0",
    "astro": "^6.0.1",
    "satori": "^0.26.0",
    "sharp": "^0.34.2",
    "starlight-github-alerts": "^0.2.0",
    "starlight-typedoc": "^0.21.5",
    "starlight-versions": "^0.8.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
