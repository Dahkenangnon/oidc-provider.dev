---
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<div class="license-footer">
	<p>
		Documentation content licensed under <a href="https://creativecommons.org/licenses/by-sa/4.0/" target="_blank" rel="noopener">CC-BY-SA 4.0</a>.
		Code licensed under <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT</a>.
		<br />
		<a href="https://github.com/panva/node-oidc-provider" target="_blank" rel="noopener">oidc-provider</a> by <a href="https://github.com/panva" target="_blank" rel="noopener">panva</a>, licensed under MIT.
	</p>
</div>

<style>
	.license-footer {
		border-top: 1px solid var(--sl-color-gray-5);
		padding-top: 1.5rem;
		margin-top: 1.5rem;
		text-align: center;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}
	.license-footer a {
		color: var(--sl-color-gray-2);
		text-decoration: underline;
	}
	.license-footer a:hover {
		color: var(--sl-color-white);
	}
</style>
